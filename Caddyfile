{
    auto_https off
}

:80 {
    # Frontend (React SPA)
    reverse_proxy frontend:8080

    # Backend API
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy backend:80
    }

    log {
        output stdout
        format json
    }
}

# Uptime Kuma monitoring dashboard
:3001 {
    reverse_proxy uptime-kuma:3001
}
